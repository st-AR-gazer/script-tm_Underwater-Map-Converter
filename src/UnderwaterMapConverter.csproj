<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishSingleFile Condition="'$(RuntimeIdentifier)' != ''">true</PublishSingleFile>
    <SelfContained Condition="'$(RuntimeIdentifier)' != ''">true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract Condition="'$(PublishSingleFile)' == 'true'">true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GBX.NET" Version="2.*" />
    <PackageReference Include="GBX.NET.LZO" Version="2.*" />
    <PackageReference Include="GBX.NET.ZLib" Version="1.*" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\\assets\\blocks\\*.Block.Gbx" LogicalName="BundledAssets.blocks.%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\\assets\\maps\\*.Map.Gbx" LogicalName="BundledAssets.maps.%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
